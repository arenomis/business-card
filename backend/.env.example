# Пример конфигурации API. Скопируйте в backend/.env и подставьте значения.
# Для облака те же имена переменных задаются в панели хостинга.

PORT=3000
CORS_ORIGIN=http://localhost:4200

# --- Почта (выберите один способ) ---

# Рекомендуется: Resend — https://resend.com (бесплатный план), один API-ключ
RESEND_API_KEY=
# От кого (для теста можно оставить как ниже; для продакшена — домен в Resend)
RESEND_FROM="Developer Landing <onboarding@resend.dev>"

# Куда приходит заявка
OWNER_EMAIL=ardashovaleksei@gmail.com
OWNER_NAME=Алексей Ардашов

# Когда RESEND_FROM = onboarding@resend.dev: копия заявителю уходит через SMTP ниже (например Brevo).
# Альтернатива без SMTP: подтвердите домен в Resend и смените RESEND_FROM на свой домен.

# SMTP (для копии при тестовом Resend, или для полной отправки без Resend)
# Важно: smtp.gmail.com с локалки часто ок, с Render/VPS — Google часто блокирует. Для продакшена лучше Brevo ниже.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# На Render задайте те же SMTP_* что и локально (частая ошибка — другой SMTP_PASS или пустой SMTP_USER).
# В логах: «[mail] applicant copy SMTP OK» / «SMTP FAIL»; при FAIL владелец получит письмо через Resend.
# Копия заявителю по SMTP в том же запросе. Таймаут всей попытки: SMTP_APPLICANT_COPY_TIMEOUT_MS (по умолчанию 48000).
# Таймауты TCP к SMTP (nodemailer): SMTP_CONNECTION_TIMEOUT_MS, SMTP_GREETING_TIMEOUT_MS, SMTP_SOCKET_TIMEOUT_MS.
# Для проверки доставки: APPLICANT_COPY_OVERRIDE_EMAIL=you@list.ru — копия уйдёт на этот ящик, в форме можно указать любой email.
# На Render не используйте smtp.gmail.com (таймаут). Обход только для отладки: SMTP_ALLOW_GMAIL_ON_RENDER=true

# Только лог в консоль (без отправки): EMAIL_DEV_MOCK=true

# --- AI ---
AI_USE_POLLINATIONS=true
# Ollama только если сервис доступен по OLLAMA_BASE_URL с этого сервера:
AI_USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
