# Пример конфигурации API. Скопируйте в backend/.env и подставьте значения.
# Для облака те же имена переменных задаются в панели хостинга.
#
# Важно: не копируйте в локальный .env переменную RENDER=true с Render — на Render её задаёт платформа сама.
# Если RENDER=true локально, копия через smtp.gmail.com будет сразу отключена (как в облаке).

PORT=3000
# Опционально для длинных POST: HTTP_KEEP_ALIVE_TIMEOUT_MS, HTTP_HEADERS_TIMEOUT_MS, HTTP_REQUEST_TIMEOUT_MS (0 = без лимита приёма запроса)
CORS_ORIGIN=http://localhost:4200

# --- Почта (выберите один способ) ---

# Рекомендуется: Resend — https://resend.com (бесплатный план), один API-ключ
RESEND_API_KEY=
# От кого (для теста можно оставить как ниже; для продакшена — домен в Resend)
RESEND_FROM="Developer Landing <onboarding@resend.dev>"

# Куда приходит заявка
OWNER_EMAIL=ardashovaleksei@gmail.com
OWNER_NAME=Алексей Ардашов

# Когда RESEND_FROM = onboarding@resend.dev: копия заявителю уходит через SMTP ниже (например Brevo).
# Альтернатива без SMTP: подтвердите домен в Resend и смените RESEND_FROM на свой домен.

# SMTP (для копии при тестовом Resend, или для полной отправки без Resend)
# Важно: smtp.gmail.com с локалки часто ок, с Render/VPS — Google часто блокирует. Для продакшена лучше Brevo ниже.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Brevo: SMTP_HOST=smtp-relay.brevo.com, SMTP_USER=логин из SMTP & API (часто *@smtp-brevo.com), SMTP_PASS=SMTP-ключ (не пароль входа на brevo.com).
# В Brevo → Senders должен быть подтверждён адрес, который подставляется в «От» (обычно OWNER_EMAIL); иначе задайте SMTP_FROM="Имя <подтверждённый@email>".
# На Render задайте те же SMTP_* что и локально (частая ошибка — другой SMTP_PASS или пустой SMTP_USER).
# В логах: «[mail] applicant copy SMTP OK» / «SMTP FAIL»; при FAIL владелец получит письмо через Resend.
# Копия заявителю: сначала второй запрос Resend; если не выходит (onboarding@resend.dev) — SMTP в том же запросе.
# Если копия «не приходит», хотя Resend не ругается: APPLICANT_COPY_FORCE_SMTP=true — копия только через SMTP (Brevo), без второго Resend.
# Таймаут SMTP-копии: SMTP_APPLICANT_COPY_TIMEOUT_MS (по умолчанию 25000). При «таймаут 25000 мс» сначала проверьте сеть до Brevo; при необходимости 45000–60000.
# Таймауты TCP к SMTP (nodemailer): SMTP_CONNECTION_TIMEOUT_MS, SMTP_GREETING_TIMEOUT_MS, SMTP_SOCKET_TIMEOUT_MS.
# Если до smtp-relay.brevo.com «висит» подключение: SMTP_FORCE_IPV4=true (обход битого IPv6).
# Postfix с relayhost на Brevo на ЭТОМ же сервере, где Node: в приложении SMTP_HOST=127.0.0.1 и порт локального smtpd (не обязательно внешний smtp-relay).
# Для проверки доставки: APPLICANT_COPY_OVERRIDE_EMAIL=you@list.ru — копия уйдёт на этот ящик, в форме можно указать любой email.
# На Render не используйте smtp.gmail.com (таймаут). Обход только для отладки: SMTP_ALLOW_GMAIL_ON_RENDER=true

# Только лог в консоль (без отправки): EMAIL_DEV_MOCK=true

# --- AI (ассистент на сайте) ---
# Groq: https://console.groq.com/keys → AI_GROQ_API_KEY в этом файле или в backend/.env.local (не в git)
AI_USE_GROQ=true
# AI_GROQ_API_KEY=
# AI_GROQ_MODEL=llama-3.1-8b-instant

AI_USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
